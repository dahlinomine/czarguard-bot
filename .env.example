# ─── CZAR Operator Harness — Environment Config ───────────────────────────────
# Railway: add these as Variables in the dashboard (Settings → Variables)
# Local:   cp .env.example .env and fill in values

# ─── Security (generate fresh secrets) ────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_SECRET_KEY=change-me-jwt-secret-use-openssl-rand-hex-32

# ─── Database & Cache (Railway adds these automatically as plugins) ────────────
# DATABASE_URL=postgresql+asyncpg://...  ← injected by Railway Postgres plugin
# REDIS_URL=redis://...                  ← injected by Railway Redis plugin

# ─── LLM — ChatAnywhere (OpenAI-compatible, free tier) ───────────────────────
# Add your key in the dashboard under Model Settings after first login
# These env vars let you pre-seed the model pool on startup:
CZAR_LLM_API_KEY=sk-your-chatanywhere-key-here
CZAR_LLM_BASE_URL=https://api.chatanywhere.tech/v1
CZAR_LLM_FAST_MODEL=gpt-4o-mini-ca
CZAR_LLM_REASON_MODEL=deepseek-v3
CZAR_LLM_DEEP_MODEL=deepseek-r1-0528

# ─── Telegram Gateway (czarguard_bot joins as OpenClaw agent) ─────────────────
TELEGRAM_BOT_TOKEN=TELEGRAM_TOKEN_REMOVED
TELEGRAM_CHAT_ID=7589238550

# ─── Platform Integrations ────────────────────────────────────────────────────
JINA_API_KEY=                        # Jina AI search (free tier, get at jina.ai)

# ─── Railway Config ───────────────────────────────────────────────────────────
AGENT_DATA_DIR=/data/agents
PORT=8000
FRONTEND_PORT=3000
